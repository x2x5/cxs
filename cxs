#!/usr/bin/env bash
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# cxs - Codex 多账号切换器
#
# 结构：
#   ~/codex-accounts/
#   ├── base_config.toml      ← 基础模板（共享，所有账号通用的配置）
#   ├── alice/
#   │   └── auth.json         ← OAuth 凭据
#   ├── bob/
#   │   └── auth.json         ← API Key（含 base_url）
#   └── carol/
#       └── auth.json         ← 另一个 API Key
#
# auth.json 格式：
#   OAuth:   {"mode": "oauth", "tokens": {"access_token": "...", "account_id": "..."}}
#   API Key: {"api_key": "sk-xxx"}
#   中转站:  {"api_key": "sk-xxx", "base_url": "https://xxx.com/v1"}
#
# 切换逻辑：
#   OAuth   → 只换 auth.json，不动 config.toml
#   API Key → 换 auth.json，把 base_url 注入基础模板生成 config.toml
#
# 用法：
#   cxs list                列出所有账号
#   cxs switch <名称>        切换到指定账号
#   cxs current             显示当前账号
#   cxs status              总览：所有账号 + 额度
#   cxs quota [名称]         查看额度
#   cxs auto                自动切换到额度最多的账号
#   cxs add <名称>           创建新账号
#   cxs edit <名称>          编辑账号配置
#   cxs diff <名称>          对比
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

set -euo pipefail

# ═══════════════════════════════════════════════════════
# 配置
# ═══════════════════════════════════════════════════════
ACCOUNTS_DIR="${CX_ACCOUNTS_DIR:-$HOME/codex-accounts}"
CODEX_DIR="$HOME/.codex"
CURRENT_FILE="$CODEX_DIR/.current_account"
BASE_CONFIG="$ACCOUNTS_DIR/base_config.toml"

# 颜色
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

mkdir -p "$ACCOUNTS_DIR"

# ═══════════════════════════════════════════════════════
# 内部函数
# ═══════════════════════════════════════════════════════

get_current() {
    [[ -f "$CURRENT_FILE" ]] && cat "$CURRENT_FILE" || echo ""
}

# 从 auth.json 读取凭据
get_auth_info() {
    local account="$1"
    local field="$2"
    local auth_file="$ACCOUNTS_DIR/$account/auth.json"
    
    python3 -c "
import json, sys, os

field = '$field'
auth_file = '$auth_file'

auth = {}
if os.path.exists(auth_file):
    try:
        auth = json.load(open(auth_file))
    except:
        pass

if field == 'mode':
    if 'tokens' in auth and 'access_token' in auth.get('tokens', {}):
        print('oauth')
    elif 'api_key' in auth or 'openai_api_key' in auth:
        print('api_key')
    else:
        print('unknown')
elif field == 'access_token':
    tokens = auth.get('tokens', {})
    print(tokens.get('access_token', auth.get('access_token', '')))
elif field == 'account_id':
    tokens = auth.get('tokens', {})
    print(tokens.get('account_id', auth.get('account_id', '')))
elif field == 'api_key':
    for k in ['api_key', 'openai_api_key', 'OPENAI_API_KEY', 'key']:
        if k in auth:
            print(auth[k])
            sys.exit(0)
elif field == 'base_url':
    print(auth.get('base_url', ''))
" 2>/dev/null
}

# 列出所有账号
list_accounts() {
    if [[ -d "$ACCOUNTS_DIR" ]]; then
        for dir in "$ACCOUNTS_DIR"/*/; do
            [[ -d "$dir" ]] && basename "$dir"
        done
    fi
}

# 检查账号是否有效
validate_account() {
    local account="$1"
    [[ -f "$ACCOUNTS_DIR/$account/auth.json" ]]
}

# 生成 config.toml：把基础模板里的 {{BASE_URL}} 替换成实际地址
generate_config() {
    local base_url="$1"
    
    if [[ ! -f "$BASE_CONFIG" ]]; then
        # 没有基础模板，直接写一个最小配置
        if [[ -n "$base_url" ]]; then
            cat > "$CODEX_DIR/config.toml" << EOF
base_url = "$base_url"
EOF
        fi
        return
    fi
    
    if [[ -n "$base_url" ]]; then
        # 有 base_url，替换模板里的占位符
        sed "s|{{BASE_URL}}|$base_url|g" "$BASE_CONFIG" > "$CODEX_DIR/config.toml"
    else
        # 没有 base_url，删除占位符行或保留模板原样
        sed '/{{BASE_URL}}/d' "$BASE_CONFIG" > "$CODEX_DIR/config.toml"
    fi
}

# 检查额度
check_account_quota() {
    local account="$1"
    local mode
    mode=$(get_auth_info "$account" "mode")
    
    if [[ "$mode" == "oauth" ]]; then
        local access_token account_id
        access_token=$(get_auth_info "$account" "access_token")
        account_id=$(get_auth_info "$account" "account_id")
        
        if [[ -z "$access_token" ]]; then
            echo '{"success": false, "error": "No access_token"}'
            return
        fi
        
        local curl_cmd="curl -s --max-time 10"
        curl_cmd="$curl_cmd -H 'Authorization: Bearer $acces..."
        curl_cmd="$curl_cmd -H 'User-Agent: codex-cli'"
        curl_cmd="$curl_cmd -H 'Accept: application/json'"
        [[ -n "$account_id" ]] && curl_cmd="$curl_cmd -H 'ChatGPT-Account-Id: $account_id'"
        curl_cmd="$curl_cmd 'https://chatgpt.com/backend-api/wham/usage'"
        
        local response
        response=$(eval "$curl_cmd" 2>/dev/null || echo "")
        
        if [[ -z "$response" ]]; then
            echo '{"success": false, "error": "Network error"}'
            return
        fi
        
        python3 -c "
import json, sys

try:
    data = json.loads('''$response''')
except:
    print(json.dumps({'success': False, 'error': 'Invalid JSON'}))
    sys.exit(0)

rate_limit = data.get('rate_limit', {})
windows = []

for w in [rate_limit.get('primary_window', {}), rate_limit.get('secondary_window', {})]:
    if not w or 'used_percent' not in w:
        continue
    secs = w.get('limit_window_seconds', 0)
    used = w['used_percent']
    remaining = round(100.0 - used, 1)
    reset_at = w.get('reset_at')
    
    if secs == 18000: name = '5小时'
    elif secs == 604800: name = '7天'
    elif secs >= 86400: name = f'{secs // 86400}天'
    else: name = f'{secs // 3600}小时'
    
    reset_str = ''
    if reset_at:
        from datetime import datetime, timezone
        try:
            dt = datetime.fromtimestamp(reset_at, tz=timezone.utc).astimezone()
            now = datetime.now(tz=timezone.utc).astimezone()
            diff = dt - now
            if diff.total_seconds() > 0:
                h = int(diff.total_seconds() // 3600)
                m = int((diff.total_seconds() % 3600) // 60)
                reset_str = f'{h}h{m}m后刷新' if h > 0 else f'{m}m后刷新'
            else:
                reset_str = '即将刷新'
        except: pass
    
    windows.append({'name': name, 'used_percent': used, 'remaining_percent': remaining, 'reset_str': reset_str})

if windows:
    print(json.dumps({'success': True, 'windows': windows}))
else:
    print(json.dumps({'success': False, 'error': 'No rate_limit data'}))
" 2>/dev/null
    else
        # API Key 模式无法查额度
        echo '{"success": false, "error": "API Key 模式不支持额度查询"}'
    fi
}

# ═══════════════════════════════════════════════════════
# 命令
# ═══════════════════════════════════════════════════════

cmd_list() {
    echo -e "${CYAN}${BOLD}📋 账号列表${NC}"
    echo ""
    
    local current
    current=$(get_current)
    
    local found=0
    for name in $(list_accounts); do
        found=1
        local icon="${BLUE}  ${NC}"
        [[ "$name" == "$current" ]] && icon="${GREEN}▶${NC}"
        
        local valid
        validate_account "$name" && valid="${GREEN}✓${NC}" || valid="${RED}✗${NC}"
        
        local mode
        mode=$(get_auth_info "$name" "mode")
        local mode_str=""
        case "$mode" in
            oauth)   mode_str="${DIM}[OAuth]${NC}" ;;
            api_key)
                local url
                url=$(get_auth_info "$name" "base_url")
                [[ -n "$url" ]] && mode_str="${DIM}[中转站]${NC}" || mode_str="${DIM}[API Key]${NC}"
                ;;
        esac
        
        local extra=""
        [[ "$name" == "$current" ]] && extra=" ${GREEN}← 当前${NC}"
        echo -e "  $icon ${BOLD}$name${NC}  $valid $mode_str$extra"
    done
    
    if [[ $found -eq 0 ]]; then
        echo -e "  ${YELLOW}还没有账号${NC}"
        echo -e "  用法: ${GREEN}cxs add <名称>${NC}"
    fi
}

cmd_switch() {
    local name="$1"
    [[ -z "$name" ]] && { echo -e "${RED}❌ 请指定账号名称${NC}"; cmd_list; return 1; }
    
    local account_dir="$ACCOUNTS_DIR/$name"
    [[ ! -d "$account_dir" ]] && { echo -e "${RED}❌ 账号 '$name' 不存在${NC}"; cmd_list; return 1; }
    validate_account "$name" || { echo -e "${RED}❌ 账号 '$name' 缺少 auth.json${NC}"; return 1; }
    
    mkdir -p "$CODEX_DIR"
    
    # 1. 切换 auth.json
    cp "$account_dir/auth.json" "$CODEX_DIR/auth.json"
    echo -e "  ${GREEN}✓${NC} auth.json"
    
    # 2. 处理 config.toml
    local mode
    mode=$(get_auth_info "$name" "mode")
    
    if [[ "$mode" == "api_key" ]]; then
        local base_url
        base_url=$(get_auth_info "$name" "base_url")
        generate_config "$base_url"
        if [[ -n "$base_url" ]]; then
            echo -e "  ${GREEN}✓${NC} config.toml (中转站: $base_url)"
        else
            echo -e "  ${GREEN}✓${NC} config.toml (基础模板)"
        fi
    else
        # OAuth 模式：不动 config.toml，或用基础模板
        if [[ -f "$BASE_CONFIG" ]]; then
            generate_config ""
            echo -e "  ${GREEN}✓${NC} config.toml (基础模板)"
        else
            echo -e "  ${DIM}○${NC} config.toml (未改动)"
        fi
    fi
    
    echo "$name" > "$CURRENT_FILE"
    echo ""
    echo -e "${GREEN}${BOLD}✅ 已切换到: $name${NC}"
}

cmd_current() {
    local current
    current=$(get_current)
    
    if [[ -n "$current" ]]; then
        echo -e "${CYAN}当前账号:${NC} ${GREEN}${BOLD}$current${NC}"
        
        local mode
        mode=$(get_auth_info "$current" "mode")
        case "$mode" in
            oauth)   echo -e "${CYAN}模式:${NC} OAuth" ;;
            api_key)
                local base_url
                base_url=$(get_auth_info "$current" "base_url")
                if [[ -n "$base_url" ]]; then
                    echo -e "${CYAN}模式:${NC} API Key (中转站)"
                    echo -e "${CYAN}地址:${NC} $base_url"
                else
                    echo -e "${CYAN}模式:${NC} API Key"
                fi
                ;;
        esac
        
        local api_key
        api_key=$(get_auth_info "$current" "api_key")
        [[ -z "$api_key" ]] && api_key=$(get_auth_info "$current" "access_token")
        if [[ -n "$api_key" && ${#api_key} -gt 8 ]]; then
            echo -e "${CYAN}凭据:${NC} ${api_key:0:8}...${api_key: -4}"
        fi
    else
        echo -e "${YELLOW}还没有选择任何账号${NC}"
    fi
    
    echo ""
    echo -e "${CYAN}当前文件:${NC}"
    [[ -f "$CODEX_DIR/auth.json" ]] && echo -e "  ${GREEN}✓${NC} $CODEX_DIR/auth.json" || echo -e "  ${RED}✗${NC} $CODEX_DIR/auth.json"
    [[ -f "$CODEX_DIR/config.toml" ]] && echo -e "  ${GREEN}✓${NC} $CODEX_DIR/config.toml" || echo -e "  ${RED}✗${NC} $CODEX_DIR/config.toml"
}

cmd_quota() {
    local target="$1"
    
    if [[ -n "$target" ]]; then
        echo -e "${CYAN}检查: ${BOLD}$target${NC}"
        echo ""
        local result
        result=$(check_account_quota "$target")
        local success
        success=$(echo "$result" | python3 -c "import json,sys; print(json.load(sys.stdin).get('success',False))" 2>/dev/null)
        
        if [[ "$success" == "True" ]]; then
            echo -e "  ${GREEN}✓${NC} 查询成功"
            python3 -c "
import json, sys
d = json.loads('''$result''')
for w in d.get('windows', []):
    reset = f\"  ({w['reset_str']})\" if w.get('reset_str') else ''
    print(f\"  {w['name']}: 剩余{w['remaining_percent']}% (已用{w['used_percent']}%){reset}\")
" 2>/dev/null
        else
            local error
            error=$(echo "$result" | python3 -c "import json,sys; print(json.load(sys.stdin).get('error',''))" 2>/dev/null)
            echo -e "  ${RED}✗ $error${NC}"
        fi
    else
        echo -e "${CYAN}${BOLD}📊 所有账号额度${NC}"
        echo ""
        local current
        current=$(get_current)
        
        for name in $(list_accounts); do
            local marker="  "
            [[ "$name" == "$current" ]] && marker="${GREEN}▶${NC}"
            
            local result
            result=$(check_account_quota "$name")
            local success
            success=$(echo "$result" | python3 -c "import json,sys; print(json.load(sys.stdin).get('success',False))" 2>/dev/null)
            
            if [[ "$success" == "True" ]]; then
                local info
                info=$(echo "$result" | python3 -c "
import json, sys
d = json.load(sys.stdin)
parts = [f\"{w['remaining_percent']}%({w['name']}{', ' + w['reset_str'] if w.get('reset_str') else ''})\" for w in d.get('windows', [])]
print(' | '.join(parts))
" 2>/dev/null)
                echo -e "  $marker ${BOLD}$name${NC}  ${GREEN}${info}${NC}"
            else
                echo -e "  $marker ${BOLD}$name${NC}  ${DIM}无法查询${NC}"
            fi
        done
    fi
}

cmd_auto() {
    echo -e "${CYAN}${BOLD}🔄 自动切换到额度最多的账号...${NC}"
    echo ""
    
    local best_name="" best_remaining="-1"
    
    for name in $(list_accounts); do
        validate_account "$name" || continue
        
        local result
        result=$(check_account_quota "$name")
        local success
        success=$(echo "$result" | python3 -c "import json,sys; print(json.load(sys.stdin).get('success',False))" 2>/dev/null)
        
        if [[ "$success" == "True" ]]; then
            local remaining info
            remaining=$(echo "$result" | python3 -c "import json,sys; w=json.load(sys.stdin).get('windows',[]); print(w[0]['remaining_percent'] if w else 0)" 2>/dev/null)
            info=$(echo "$result" | python3 -c "
import json, sys
d = json.load(sys.stdin)
parts = [f\"{w['remaining_percent']}%({w['name']}{', ' + w['reset_str'] if w.get('reset_str') else ''})\" for w in d.get('windows', [])]
print(' | '.join(parts))
" 2>/dev/null)
            echo -e "  检查 $name ... ${GREEN}${info}${NC}"
            
            local is_better
            is_better=$(python3 -c "print(1 if float($remaining) > float($best_remaining) else 0)" 2>/dev/null || echo "0")
            [[ "$is_better" == "1" ]] && { best_name="$name"; best_remaining="$remaining"; }
        else
            echo -e "  检查 $name ... ${DIM}跳过${NC}"
        fi
    done
    
    echo ""
    [[ -z "$best_name" ]] && { echo -e "${YELLOW}⚠ 没有可查额度的账号（需要 OAuth 模式）${NC}"; return 1; }
    
    echo -e "最佳: ${GREEN}${BOLD}$best_name${NC} (剩余 ${best_remaining}%)"
    echo ""
    cmd_switch "$best_name"
}

cmd_status() {
    echo -e "${CYAN}${BOLD}╔═══════════════════════════════════════╗${NC}"
    echo -e "${CYAN}${BOLD}║       Codex 多账号状态总览            ║${NC}"
    echo -e "${CYAN}${BOLD}╚═══════════════════════════════════════╝${NC}"
    echo ""
    
    local current
    current=$(get_current)
    [[ -n "$current" ]] && echo -e "  当前账号: ${GREEN}${BOLD}$current${NC}" || echo -e "  当前账号: ${YELLOW}未设置${NC}"
    echo -e "  账号目录: ${DIM}$ACCOUNTS_DIR${NC}"
    [[ -f "$BASE_CONFIG" ]] && echo -e "  基础模板: ${GREEN}✓${NC}" || echo -e "  基础模板: ${YELLOW}无${NC} ${DIM}(API Key 中转站需要)${NC}"
    echo ""
    
    echo -e "${BOLD}  账号            模式        剩余额度${NC}"
    echo -e "  ─────────────── ─────────── ─────────"
    
    for name in $(list_accounts); do
        local marker=" "
        [[ "$name" == "$current" ]] && marker="${GREEN}▶${NC}"
        
        local mode mode_str
        mode=$(get_auth_info "$name" "mode")
        case "$mode" in
            oauth)   mode_str="OAuth     " ;;
            api_key)
                local url
                url=$(get_auth_info "$name" "base_url")
                [[ -n "$url" ]] && mode_str="中转站     " || mode_str="API Key   "
                ;;
            *)       mode_str="未知       " ;;
        esac
        
        # 额度
        local quota_str
        if [[ "$mode" == "oauth" ]]; then
            local result
            result=$(check_account_quota "$name")
            local success
            success=$(echo "$result" | python3 -c "import json,sys; print(json.load(sys.stdin).get('success',False))" 2>/dev/null)
            if [[ "$success" == "True" ]]; then
                quota_str=$(echo "$result" | python3 -c "
import json, sys
d = json.load(sys.stdin)
parts = [f\"{w['remaining_percent']}%({w['name']}{', ' + w['reset_str'] if w.get('reset_str') else ''})\" for w in d.get('windows', [])]
print(' | '.join(parts))
" 2>/dev/null)
                quota_str="${GREEN}${quota_str}${NC}"
            else
                quota_str="${YELLOW}查询失败${NC}"
            fi
        else
            quota_str="${DIM}-${NC}"
        fi
        
        printf "  %s %-15s %b %b\n" "$marker" "$name" "$mode_str" "$quota_str"
    done
    
    echo ""
    echo -e "${DIM}  cxs switch <名称>  切换${NC}"
    echo -e "${DIM}  cxs auto           自动选额度最多的${NC}"
}

cmd_add() {
    local name="$1"
    
    # 自动生成名称：月日-时分秒-随机英文名
    if [[ -z "$name" ]]; then
        local timestamp random_words
        timestamp=$(date +%m%d-%H%M%S)
        random_words=("breeze" "swift" "coral" "flame" "lunar" "nova" "pixel" "spark" "storm" "tide" "atlas" "cedar" "drift" "ember" "frost" "glyph" "haze" "iris" "jade" "kite" "mist" "neon" "opal" "peak" "reef" "sage" "vine" "wolf" "zeal" "arch")
        local idx=$((RANDOM % ${#random_words[@]}))
        name="${timestamp}-${random_words[$idx]}"
    fi
    
    local account_dir="$ACCOUNTS_DIR/$name"
    [[ -d "$account_dir" ]] && { echo -e "${YELLOW}⚠ 账号 '$name' 已存在${NC}"; return 1; }
    
    mkdir -p "$account_dir"
    
    echo -e "${CYAN}选择模式:${NC}"
    echo "  1) 中转站 (输入 URL 和 Key)"
    echo "  2) OAuth (自己复制 auth.json)"
    echo ""
    echo -n "选择 [1/2]: "
    read -r choice
    
    case "$choice" in
        1)
            echo ""
            echo -n "中转站 URL (如 https://xxx.com/v1): "
            read -r base_url
            echo -n "API Key: "
            read -r api_key
            
            if [[ -z "$base_url" || -z "$api_key" ]]; then
                echo -e "${RED}❌ URL 和 Key 不能为空${NC}"
                rmdir "$account_dir" 2>/dev/null
                return 1
            fi
            
            # 生成 auth.json
            python3 -c "
import json
data = {'api_key': '$api_key', 'base_url': '$base_url'}
with open('$account_dir/auth.json', 'w') as f:
    json.dump(data, f, indent=2)
"
            echo ""
            echo -e "${GREEN}${BOLD}✅ 已创建: $name${NC} (中转站)"
            echo -e "  URL: $base_url"
            echo -e "  Key: ${api_key:0:8}..."
            ;;
        2)
            # 创建空的 auth.json 占位
            cat > "$account_dir/auth.json" << 'EOF'
{
  "mode": "oauth",
  "tokens": {
    "access_token": "",
    "account_id": ""
  }
}
EOF
            echo ""
            echo -e "${GREEN}${BOLD}✅ 已创建: $name${NC} (OAuth)"
            echo ""
            echo -e "  请用 cxs edit $name 编辑 auth.json，填入你的 OAuth 凭据"
            echo -e "  或者直接复制你已有的 auth.json 到:"
            echo -e "  ${DIM}$account_dir/auth.json${NC}"
            ;;
        *)
            echo -e "${RED}无效选择${NC}"
            rmdir "$account_dir" 2>/dev/null
            return 1
            ;;
    esac
    
    # 检查基础模板
    if [[ ! -f "$BASE_CONFIG" ]]; then
        echo ""
        echo -e "  ${YELLOW}提示:${NC} 没有基础模板 $BASE_CONFIG"
        echo -e "  中转站模式需要它，建议创建:"
        echo -e "    ${DIM}model = \"o3\"${NC}"
        echo -e "    ${DIM}provider = \"openai\"${NC}"
        echo -e "    ${DIM}base_url = \"{{BASE_URL}}\"${NC}"
    fi
}

cmd_edit() {
    local name="$1"
    [[ -z "$name" ]] && { echo -e "${RED}❌ 请指定账号名称${NC}"; return 1; }
    [[ ! -d "$ACCOUNTS_DIR/$name" ]] && { echo -e "${RED}❌ 账号 '$name' 不存在${NC}"; return 1; }
    
    local editor="${EDITOR:-nano}"
    $editor "$ACCOUNTS_DIR/$name/auth.json"
    echo -e "${GREEN}✅ 已编辑 $name/auth.json${NC}"
}

cmd_diff() {
    local name="$1"
    [[ -z "$name" ]] && { echo -e "${RED}❌ 请指定账号名称${NC}"; return 1; }
    [[ ! -d "$ACCOUNTS_DIR/$name" ]] && { echo -e "${RED}❌ 账号 '$name' 不存在${NC}"; return 1; }
    
    echo -e "${CYAN}对比: 当前 vs $name${NC}"
    echo ""
    echo -e "${BLUE}━━━ auth.json ━━━${NC}"
    if [[ -f "$CODEX_DIR/auth.json" && -f "$ACCOUNTS_DIR/$name/auth.json" ]]; then
        diff --color=auto "$CODEX_DIR/auth.json" "$ACCOUNTS_DIR/$name/auth.json" || true
    else
        echo -e "  ${YELLOW}一边缺少文件${NC}"
    fi
}

cmd_help() {
    echo -e "${CYAN}${BOLD}cxs - Codex 多账号切换器${NC}"
    echo ""
    echo "用法:"
    echo "  cxs list              列出所有账号"
    echo "  cxs switch <名称>      切换到指定账号"
    echo "  cxs current           显示当前账号"
    echo "  cxs status            总览"
    echo "  cxs quota [名称]       查看额度"
    echo "  cxs auto              自动选额度最多的"
    echo "  cxs add <名称>         创建新账号"
    echo "  cxs edit <名称>        编辑 auth.json"
    echo "  cxs diff <名称>        对比"
    echo ""
    echo "目录结构:"
    echo "  ~/codex-accounts/"
    echo "  ├── base_config.toml   ← 基础模板（中转站用，写 {{BASE_URL}} 占位符）"
    echo "  ├── alice/"
    echo "  │   └── auth.json"
    echo "  └── bob/"
    echo "      └── auth.json"
    echo ""
    echo "auth.json 格式:"
    echo "  API Key:  {\"api_key\": \"sk-xxx\"}"
    echo "  中转站:   {\"api_key\": \"sk-xxx\", \"base_url\": \"https://xxx.com/v1\"}"
    echo "  OAuth:    {\"mode\": \"oauth\", \"tokens\": {\"access_token\": \"...\", \"account_id\": \"...\"}}"
}

# ═══════════════════════════════════════════════════════
# 入口
# ═══════════════════════════════════════════════════════
case "${1:-help}" in
    list|ls)        cmd_list ;;
    switch|sw)      cmd_switch "${2:-}" ;;
    current|cur)    cmd_current ;;
    quota)          cmd_quota "${2:-}" ;;
    auto)           cmd_auto ;;
    status|st)      cmd_status ;;
    add|new)        cmd_add "${2:-}" ;;
    edit)           cmd_edit "${2:-}" ;;
    diff)           cmd_diff "${2:-}" ;;
    help|-h|--help) cmd_help ;;
    *)
        echo -e "${RED}❌ 未知命令: $1${NC}"
        cmd_help
        ;;
esac
