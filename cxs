#!/usr/bin/env bash
# cxs - Codex 多账号切换器
# https://github.com/x2x5/cxs

set -euo pipefail

ACCOUNTS_DIR="${CX_ACCOUNTS_DIR:-$HOME/codex-accounts}"
CODEX_DIR="$HOME/.codex"
CURRENT_FILE="$CODEX_DIR/.current_account"
BASE_CONFIG="$ACCOUNTS_DIR/base_config.toml"
CXSLIB="/tmp/.cxs_$$_lib.py"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; DIM='\033[2m'; BOLD='\033[1m'; NC='\033[0m'

mkdir -p "$ACCOUNTS_DIR"

# Write Python helper library
cat > "$CXSLIB" << 'CXSPYEOF'
import json, sys, os
from datetime import datetime, timezone

def read_auth(account_dir):
    auth_file = os.path.join(account_dir, "auth.json")
    if os.path.exists(auth_file):
        try: return json.load(open(auth_file))
        except: pass
    return {}

def read_base_url(account_dir):
    config_file = os.path.join(account_dir, "config.toml")
    if os.path.exists(config_file):
        try:
            for l in open(config_file):
                l = l.strip()
                if l.startswith("base_url") and "=" in l:
                    return l.split("=", 1)[1].strip().strip(chr(34)).strip(chr(39))
        except: pass
    return ""

def get_mode(account_dir):
    a = read_auth(account_dir)
    if "tokens" in a and "access_token" in a.get("tokens", {}):
        return "oauth"
    elif "api_key" in a or "openai_api_key" in a:
        return "api_key"
    return "unknown"

def get_field(account_dir, field):
    a = read_auth(account_dir)
    cb = read_base_url(account_dir)
    if field == "mode": return get_mode(account_dir)
    elif field == "access_token": return a.get("tokens", {}).get("access_token", a.get("access_token", ""))
    elif field == "account_id": return a.get("tokens", {}).get("account_id", a.get("account_id", ""))
    elif field == "api_key":
        for k in ["api_key", "openai_api_key", "OPENAI_API_KEY", "key"]:
            if k in a: return a[k]
    elif field == "base_url": return a.get("base_url", cb)
    return ""

def parse_quota(response_text):
    try: data = json.loads(response_text)
    except: return json.dumps({"success": False, "error": "Invalid JSON"})
    rl = data.get("rate_limit", {})
    windows = []
    for w in [rl.get("primary_window", {}), rl.get("secondary_window", {})]:
        if not w or "used_percent" not in w: continue
        s = w.get("limit_window_seconds", 0)
        u = w["used_percent"]
        r = round(100 - u, 1)
        ra = w.get("reset_at")
        if s == 18000: n = "5小时"
        elif s == 604800: n = "7天"
        elif s >= 86400: n = str(s // 86400) + "天"
        else: n = str(s // 3600) + "小时"
        rs = ""
        if ra:
            try:
                dt = datetime.fromtimestamp(ra, tz=timezone.utc).astimezone()
                now = datetime.now(tz=timezone.utc).astimezone()
                df = dt - now
                if df.total_seconds() > 0:
                    h = int(df.total_seconds() // 3600)
                    m = int((df.total_seconds() % 3600) // 60)
                    rs = (str(h) + "h" + str(m) + "m后刷新") if h > 0 else (str(m) + "m后刷新")
                else: rs = "即将刷新"
            except: pass
        windows.append({"name": n, "used_percent": u, "remaining_percent": r, "reset_str": rs})
    if windows: return json.dumps({"success": True, "windows": windows})
    return json.dumps({"success": False, "error": "No rate_limit data"})

def format_quota_detailed(data):
    for w in data.get("windows", []):
        rs = "  (" + w.get("reset_str", "") + ")" if w.get("reset_str") else ""
        print("  " + w["name"] + ": remaining " + str(w["remaining_percent"]) + "% (used " + str(w["used_percent"]) + "%)" + rs)

def format_quota_compact(data):
    parts = []
    for w in data.get("windows", []):
        s = str(w["remaining_percent"]) + "%(" + w["name"]
        if w.get("reset_str"): s += ", " + w["reset_str"]
        s += ")"
        parts.append(s)
    return " | ".join(parts)

if __name__ == "__main__":
    action = sys.argv[1] if len(sys.argv) > 1 else ""
    if action == "field":
        print(get_field(sys.argv[2], sys.argv[3]))
    elif action == "parse_quota":
        print(parse_quota(sys.stdin.read()))
    elif action == "format_detailed":
        format_quota_detailed(json.loads(sys.stdin.read()))
    elif action == "format_compact":
        print(format_quota_compact(json.loads(sys.stdin.read())))
def create_auth(account_dir, api_key=None, base_url=None, mode=None):
    import os
    os.makedirs(account_dir, exist_ok=True)
    if mode == "oauth":
        d = {"mode":"oauth","tokens":{"access_token":"","account_id":""}}
    else:
        d = {"api_key": api_key, "base_url": base_url}
    json.dump(d, open(os.path.join(account_dir, "auth.json"), "w"), indent=2)

if action == "create_auth":
    create_auth(sys.argv[2], sys.argv[3] if len(sys.argv)>3 else None, sys.argv[4] if len(sys.argv)>4 else None, sys.argv[5] if len(sys.argv)>5 else None)

CXSPYEOF

# Cleanup on exit
trap "rm -f '$CXSLIB'" EXIT

get_current() { [[ -f "$CURRENT_FILE" ]] && cat "$CURRENT_FILE" || echo ""; }
get_auth_info() { python3 "$CXSLIB" field "$ACCOUNTS_DIR/$1" "$2" 2>/dev/null; }

list_accounts() {
    [[ -d "$ACCOUNTS_DIR" ]] && for d in "$ACCOUNTS_DIR"/*/; do [[ -d "$d" ]] && basename "$d"; done
}

validate_account() { [[ -f "$ACCOUNTS_DIR/$1/auth.json" ]]; }

generate_config() {
    local base_url="$1"
    if [[ ! -f "$BASE_CONFIG" ]]; then
        [[ -n "$base_url" ]] && echo "base_url = \"$base_url\"" > "$CODEX_DIR/config.toml"
        return
    fi
    [[ -n "$base_url" ]] && sed "s|{{BASE_URL}}|$base_url|g" "$BASE_CONFIG" > "$CODEX_DIR/config.toml" \
        || sed '/{{BASE_URL}}/d' "$BASE_CONFIG" > "$CODEX_DIR/config.toml"
}

check_account_quota() {
    local account="$1" mode
    mode=$(get_auth_info "$account" "mode")
    if [[ "$mode" == "oauth" ]]; then
        local access_token account_id
        access_token=$(get_auth_info "$account" "access_token")
        account_id=$(get_auth_info "$account" "account_id")
        [[ -z "$access_token" ]] && echo '{"success":false,"error":"No access_token"}' && return
        local auth_header="Authorization: Bearer ***$access_token"
        local url="https://chatgpt.com/backend-api/wham/usage"
        if [[ -n "$account_id" ]]; then
            response=$(curl -s --max-time 10 -H "$auth_header" -H "User-Agent: codex-cli" -H "Accept: application/json" -H "ChatGPT-Account-Id: $account_id" "$url" 2>/dev/null || echo "")
        else
            response=$(curl -s --max-time 10 -H "$auth_header" -H "User-Agent: codex-cli" -H "Accept: application/json" "$url" 2>/dev/null || echo "")
        fi
        [[ -z "$response" ]] && echo '{"success":false,"error":"Network error"}' && return
        echo "$response" | python3 "$CXSLIB" parse_quota
    else
        echo '{"success":false,"error":"API Key mode does not support quota query"}'
    fi
}

cmd_list() {
    echo -e "${CYAN}${BOLD}账号列表${NC}"
    echo ""
    local current=$(get_current) found=0
    for name in $(list_accounts); do
        found=1; local icon="  " extra=""
        [[ "$name" == "$current" ]] && icon="${GREEN}>${NC}" && extra=" ${GREEN}<- 当前${NC}"
        local valid; validate_account "$name" && valid="${GREEN}v${NC}" || valid="${RED}x${NC}"
        local mode=$(get_auth_info "$name" "mode") ms=""
        case "$mode" in
            oauth) ms="${DIM}[OAuth]${NC}" ;;
            api_key)
                local u=$(get_auth_info "$name" "base_url")
                [[ -n "$u" ]] && ms="${DIM}[中转站]${NC}" || ms="${DIM}[API Key]${NC}" ;;
        esac
        echo -e "  $icon ${BOLD}$name${NC}  $valid $ms$extra"
    done
    [[ $found -eq 0 ]] && echo -e "  ${YELLOW}还没有账号${NC}  用法: cxs add"
}

cmd_switch() {
    local name="$1"
    [[ -z "$name" ]] && { echo -e "${RED}请指定账号名称${NC}"; cmd_list; return 1; }
    [[ ! -d "$ACCOUNTS_DIR/$name" ]] && { echo -e "${RED}账号 '$name' 不存在${NC}"; cmd_list; return 1; }
    validate_account "$name" || { echo -e "${RED}缺少 auth.json${NC}"; return 1; }
    mkdir -p "$CODEX_DIR"
    cp "$ACCOUNTS_DIR/$name/auth.json" "$CODEX_DIR/auth.json"
    echo -e "  ${GREEN}v${NC} auth.json"
    local mode=$(get_auth_info "$name" "mode")
    if [[ "$mode" == "api_key" ]]; then
        local base_url=$(get_auth_info "$name" "base_url")
        generate_config "$base_url"
        [[ -n "$base_url" ]] && echo -e "  ${GREEN}v${NC} config.toml [中转站: $base_url]" || echo -e "  ${GREEN}v${NC} config.toml"
    else
        [[ -f "$BASE_CONFIG" ]] && { generate_config ""; echo -e "  ${GREEN}v${NC} config.toml"; } || echo -e "  ${DIM}o${NC} config.toml"
    fi
    echo "$name" > "$CURRENT_FILE"
    echo ""
    echo -e "${GREEN}${BOLD}已切换到: $name${NC}"
}

cmd_current() {
    local current=$(get_current)
    if [[ -n "$current" ]]; then
        echo -e "${CYAN}当前账号:${NC} ${GREEN}${BOLD}$current${NC}"
        local mode=$(get_auth_info "$current" "mode")
        case "$mode" in
            oauth) echo -e "${CYAN}模式:${NC} OAuth" ;;
            api_key)
                local bu=$(get_auth_info "$current" "base_url")
                echo -e "${CYAN}模式:${NC} API Key"
                [[ -n "$bu" ]] && echo -e "${CYAN}地址:${NC} $bu" ;;
        esac
        local k=$(get_auth_info "$current" "api_key"); [[ -z "$k" ]] && k=$(get_auth_info "$current" "access_token")
        [[ -n "$k" && ${#k} -gt 8 ]] && echo -e "${CYAN}凭据:${NC} ${k:0:8}...${k: -4}"
    else
        echo -e "${YELLOW}还没有选择任何账号${NC}"
    fi
}

cmd_quota() {
    local target="$1"
    if [[ -n "$target" ]]; then
        echo -e "${CYAN}检查: ${BOLD}$target${NC}"
        local r=$(check_account_quota "$target")
        local s=$(echo "$r" | python3 -c "import json,sys; print(json.load(sys.stdin).get('success',False))" 2>/dev/null)
        if [[ "$s" == "True" ]]; then
            echo -e "  ${GREEN}v${NC} 查询成功"
            echo "$r" | python3 "$CXSLIB" format_detailed
        else
            local e=$(echo "$r" | python3 -c "import json,sys; print(json.load(sys.stdin).get('error',''))" 2>/dev/null)
            echo -e "  ${RED}x $e${NC}"
        fi
    else
        echo -e "${CYAN}${BOLD}所有账号额度${NC}"
        echo ""
        local cur=$(get_current)
        for name in $(list_accounts); do
            local mk="  "; [[ "$name" == "$cur" ]] && mk="${GREEN}>${NC}"
            local r=$(check_account_quota "$name")
            local s=$(echo "$r" | python3 -c "import json,sys; print(json.load(sys.stdin).get('success',False))" 2>/dev/null)
            if [[ "$s" == "True" ]]; then
                local info=$(echo "$r" | python3 "$CXSLIB" format_compact)
                echo -e "  $mk ${BOLD}$name${NC}  ${GREEN}${info}${NC}"
            else
                echo -e "  $mk ${BOLD}$name${NC}  ${DIM}无法查询${NC}"
            fi
        done
    fi
}

cmd_auto() {
    echo -e "${CYAN}${BOLD}自动切换到额度最多的账号...${NC}"
    echo ""
    local best="" best_r="-1"
    for name in $(list_accounts); do
        validate_account "$name" || continue
        local r=$(check_account_quota "$name")
        local s=$(echo "$r" | python3 -c "import json,sys; print(json.load(sys.stdin).get('success',False))" 2>/dev/null)
        if [[ "$s" == "True" ]]; then
            local rem=$(echo "$r" | python3 -c "import json,sys; w=json.load(sys.stdin).get('windows',[]); print(w[0]['remaining_percent'] if w else 0)" 2>/dev/null)
            local info=$(echo "$r" | python3 "$CXSLIB" format_compact)
            echo -e "  检查 $name ... ${GREEN}${info}${NC}"
            local better=$(python3 -c "print(1 if $rem > $best_r else 0)" 2>/dev/null || echo 0)
            [[ "$better" == "1" ]] && { best="$name"; best_r="$rem"; }
        else
            echo -e "  检查 $name ... ${DIM}跳过${NC}"
        fi
    done
    echo ""
    [[ -z "$best" ]] && { echo -e "${YELLOW}没有可查额度的账号${NC}"; return 1; }
    echo -e "最佳: ${GREEN}${BOLD}$best${NC} [% ${best_r}%]"
    echo ""
    cmd_switch "$best"
}

cmd_status() {
    echo -e "${CYAN}${BOLD}Codex 多账号状态总览${NC}"
    echo ""
    local cur=$(get_current)
    [[ -n "$cur" ]] && echo -e "  当前账号: ${GREEN}${BOLD}$cur${NC}" || echo -e "  当前账号: ${YELLOW}未设置${NC}"
    echo -e "  账号目录: ${DIM}$ACCOUNTS_DIR${NC}"
[[ -f "$BASE_CONFIG" ]] && echo -e "  基础模板: ${GREEN}有${NC}" || echo -e "  基础模板: ${YELLOW}无${NC} ${DIM}[中转站需要]${NC}"
    echo ""
    printf "  %-17s %-11s %s\n" "账号" "模式" "剩余额度"
    echo "  ---------------   ---------   --------"
    for name in $(list_accounts); do
        local mk=" "; [[ "$name" == "$cur" ]] && mk="${GREEN}>${NC}"
        local mode=$(get_auth_info "$name" "mode") ms=""
        case "$mode" in
            oauth) ms="OAuth" ;;
            api_key)
                local u=$(get_auth_info "$name" "base_url")
                [[ -n "$u" ]] && ms="中转站" || ms="API Key" ;;
            *) ms="未知" ;;
        esac
        local qs=""
        if [[ "$mode" == "oauth" ]]; then
            local r=$(check_account_quota "$name")
            local s=$(echo "$r" | python3 -c "import json,sys; print(json.load(sys.stdin).get('success',False))" 2>/dev/null)
            if [[ "$s" == "True" ]]; then
                qs=$(echo "$r" | python3 "$CXSLIB" format_compact)
                qs="${GREEN}${qs}${NC}"
            else
                qs="${YELLOW}查询失败${NC}"
            fi
        else
            qs="${DIM}-${NC}"
        fi
        printf "  %s %-17s %-11s %b\n" "$mk" "$name" "$ms" "$qs"
    done
    echo ""
    echo -e "${DIM}  cxs switch <名称>  切换${NC}"
    echo -e "${DIM}  cxs auto           自动选额度最多的${NC}"
}

cmd_add() {
    local name="$1"
    if [[ -z "$name" ]]; then
        local ts=$(date +%m%d-%H%M%S)
        local words=("breeze" "swift" "coral" "flame" "lunar" "nova" "pixel" "spark" "storm" "tide" "atlas" "cedar" "drift" "ember" "frost" "glyph" "haze" "iris" "jade" "kite" "mist" "neon" "opal" "peak" "reef" "sage" "vine" "wolf" "zeal" "arch")
        name="${ts}-${words[$((RANDOM % ${#words[@]}))]}"
    fi
    local dir="$ACCOUNTS_DIR/$name"
    [[ -d "$dir" ]] && { echo -e "${YELLOW}账号 '$name' 已存在${NC}"; return 1; }
            python3 "$CXSLIB" create_auth "$dir" "$api_key" "$base_url"
    echo -e "${CYAN}选择模式:${NC}"
    echo "  1\] 中转站 [输入 URL 和 Key]"
    echo "  2\] OAuth [自己复制 auth.json]"
    echo ""
    echo -n "选择 [1/2]: "
    read -r choice
    case "$choice" in
        1)
            echo ""; echo -n "中转站 URL: "; read -r base_url
            echo -n "API Key: "; read -r api_key
            [[ -z "$base_url" || -z "$api_key" ]] && { echo -e "${RED}不能为空${NC}"; rmdir "$dir" 2>/dev/null; return 1; }
            echo ""
            echo -e "${GREEN}${BOLD}已创建: $name${NC} [中转站]"
            echo "  URL: $base_url"
            echo "  Key: ${api_key:0:8}..."
            ;;
        2)
            echo '{"mode":"oauth","tokens":{"access_token":"","account_id":""}}' | python3 -m json.tool > "$dir/auth.json"
            echo ""
            echo -e "${GREEN}${BOLD}已创建: $name${NC} [OAuth]"
            echo "  请编辑: $dir/auth.json"
            ;;
        *) echo -e "${RED}无效${NC}"; rmdir "$dir" 2>/dev/null; return 1 ;;
    esac
    [[ ! -f "$BASE_CONFIG" ]] && echo -e "\n  ${YELLOW}提示:${NC} 没有基础模板 $BASE_CONFIG"
}

cmd_edit() {
    local name="$1"
    [[ -z "$name" ]] && { echo -e "${RED}请指定账号名称${NC}"; return 1; }
    [[ ! -d "$ACCOUNTS_DIR/$name" ]] && { echo -e "${RED}不存在${NC}"; return 1; }
    ${EDITOR:-nano} "$ACCOUNTS_DIR/$name/auth.json"
}

cmd_diff() {
    local name="$1"
    [[ -z "$name" ]] && { echo -e "${RED}请指定名称${NC}"; return 1; }
    [[ ! -d "$ACCOUNTS_DIR/$name" ]] && { echo -e "${RED}不存在${NC}"; return 1; }
    diff --color=auto "$CODEX_DIR/auth.json" "$ACCOUNTS_DIR/$name/auth.json" 2>/dev/null || echo "  不同或缺失"
}

cmd_help() {
    echo "cxs - Codex 多账号切换器"
    echo ""
    echo "用法:"
    echo "  cxs add [名称]        添加账号"
    echo "  cxs switch <名称>     切换"
    echo "  cxs list              列出"
    echo "  cxs status            总览"
    echo "  cxs current           当前"
    echo "  cxs quota [名称]      额度"
    echo "  cxs auto              自动选额度最多的"
    echo "  cxs edit <名称>       编辑"
}

case "${1:-help}" in
    list|ls) cmd_list ;;
    switch|sw) cmd_switch "${2:-}" ;;
    current|cur) cmd_current ;;
    quota) cmd_quota "${2:-}" ;;
    auto) cmd_auto ;;
    status|st) cmd_status ;;
    add|new) cmd_add "${2:-}" ;;
    edit) cmd_edit "${2:-}" ;;
    diff) cmd_diff "${2:-}" ;;
    help|-h|--help) cmd_help ;;
    *) echo -e "${RED}未知命令: $1${NC}"; cmd_help ;;
esac
